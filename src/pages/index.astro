---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="max-w-3xl mx-auto px-6 pt-12 pb-8">
  <h1 class="text-4xl font-extrabold text-zinc-900 tracking-tight mb-2">Ramin Rasulzade</h1>
  <p class="text-lg text-zinc-700 mb-8">Technical Art Portfolio & Personal Journal</p>

  <section class="mb-12">
    <h2 class="text-2xl font-bold text-zinc-700 mb-4">Featured 3D Asset</h2>
    <model-viewer 
      src="/models/your-file-name.glb" 
      alt="A custom 3D web asset" 
      auto-rotate 
      camera-controls 
      loading="lazy"
      touch-action="pan-y"
      class="w-full h-[450px] bg-zinc-900 rounded-2xl border border-zinc-700 shadow-2xl">
    </model-viewer>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-zinc-700 mb-4">Video Showreel</h2>
    <div class="aspect-video w-full rounded-2xl overflow-hidden border border-zinc-800 shadow-2xl">
      <iframe 
        class="w-full h-full" 
        src="https://www.youtube.com/watch?v=tEK10IiBPgA" 
        title="YouTube video player" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
        allowfullscreen>
      </iframe>
    </div>
  </section>

  <section>
    <h2 class="text-2xl font-bold text-zinc-700 mb-6">Recent Articles</h2>
    </section>
</main>
		<Footer />
	</body>
</html>
