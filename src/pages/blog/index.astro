---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

// Fetch and sort posts chronologically
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white">
		<Header />
		<main class="max-w-3xl mx-auto px-4 py-16">
			<header class="mb-16 border-b border-zinc-100 pb-8">
				<h1 class="text-4xl font-extrabold tracking-tight text-zinc-900 mb-3">Technical Articles</h1>
				<p class="text-zinc-600 text-lg">Technical breakdowns, shaders and much more.</p>
			</header>

			<section>
				<ul class="space-y-2">
					{
						posts.map((post) => (
							<li class="group relative rounded-xl p-4 transition-all duration-200 hover:bg-zinc-50 border border-transparent hover:border-zinc-100">
								<a href={`/blog/${post.id}/`} class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-4 no-underline">
									
									<div class="flex items-center gap-3">
										<span class="text-blue-600 font-mono text-lg font-bold opacity-0 -translate-x-2 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0 hidden sm:block">
											&rarr;
										</span>
										<h2 class="text-xl font-semibold text-zinc-900 transition-colors duration-150 group-hover:text-blue-600">
											{post.data.title}
										</h2>
									</div>

									<time datetime={post.data.pubDate.toISOString()} class="text-sm font-mono text-zinc-400 whitespace-nowrap transition-colors duration-200 group-hover:text-zinc-600">
										{post.data.pubDate.toLocaleDateString('en-us', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
									
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>