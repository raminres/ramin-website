---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const { pathname } = Astro.url;

const hrefString = href ? href.toString() : '';

// Standardize paths by removing just the trailing slash if it exists
const sanitizedPathname = pathname.replace(/\/$/, '');
const sanitizedHref = hrefString.replace(/\/$/, '');

// 1. Activates if paths match exactly (handles exact home page and exact subpages)
// 2. Activates if it's a sub-page link, but ONLY if the link is NOT the home page ('')
const isActive = sanitizedHref === sanitizedPathname || 
                 (sanitizedHref !== '' && sanitizedPathname.startsWith(sanitizedHref + '/'));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>

<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>